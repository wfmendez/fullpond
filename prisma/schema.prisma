// FullPond ATS — Prisma schema
// Dedicated Supabase Postgres (project "FullPond"). Independent of FPY.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  USER
}

enum VacancyStatus {
  DRAFT
  OPEN
  CLOSED
}

// Recruitment pipeline stages. CLIENT_INTERVIEW = interview with the hiring
// client company; HIRED = placed with the client.
enum Stage {
  APPLIED
  SCREENING
  INTERVIEW
  CLIENT_INTERVIEW
  OFFER
  HIRED
  REJECTED
}

enum QuestionType {
  TEXT
  TEXTAREA
  SELECT
  RADIO
  NUMBER
  EMAIL
  PHONE
  URL
}

enum EmailStatus {
  RENDERED
  SENT
  FAILED
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String   @default("") // bcrypt hash
  role      Role     @default(USER)
  country   String?
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications     Application[]
  createdVacancies Vacancy[]     @relation("createdBy")
  emailLogs        EmailLog[]

  @@index([email])
}

// Companies FullPond recruits talent for.
model Client {
  id           String   @id @default(cuid())
  name         String
  contactName  String?
  contactEmail String?
  industry     String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vacancies Vacancy[]
}

model Vacancy {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  summary        String // short teaser for cards
  descriptionMd  String        @db.Text // full job description
  location       String        @default("Remote")
  employmentType String? // Full-time, Part-time, Contract
  salaryRange    String?
  status         VacancyStatus @default(DRAFT)
  clientId       String?
  createdById    String
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  client       Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdBy    User              @relation("createdBy", fields: [createdById], references: [id])
  questions    VacancyQuestion[]
  applications Application[]
  emailLogs    EmailLog[]

  @@index([status])
  @@index([clientId])
}

// Per-vacancy form questions (general + position-specific). Drives the dynamic
// application form.
model VacancyQuestion {
  id        String       @id @default(cuid())
  vacancyId String
  order     Int          @default(0)
  section   String? // "Position" | "General Questions" | custom
  label     String
  type      QuestionType @default(TEXT)
  required  Boolean      @default(false)
  options   Json? // string[] for SELECT / RADIO
  mapsTo    String? // optional: copy answer into an Application column
  //         (fullName | country | contactMethod | whatsapp | linkedin | salaryExpectation)

  vacancy Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)

  @@index([vacancyId])
}

model Application {
  id                String   @id @default(cuid())
  vacancyId         String
  userId            String
  fullName          String
  email             String
  country           String?
  contactMethod     String?
  whatsapp          String?
  linkedin          String?
  salaryExpectation String?
  answers           Json // { [questionId]: string }
  stage             Stage    @default(APPLIED)
  stageUpdatedAt    DateTime @default(now())
  notes             String?  @db.Text // recruiter notes
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  vacancy Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([vacancyId, userId])
  @@index([stage])
  @@index([vacancyId])
  @@index([userId])
}

// New-vacancy notification emails (demo mode renders + logs; sends if a Resend
// API key is configured).
model EmailLog {
  id        String      @id @default(cuid())
  vacancyId String?
  userId    String?
  toEmail   String
  subject   String
  html      String      @db.Text
  status    EmailStatus @default(RENDERED)
  createdAt DateTime    @default(now())

  vacancy Vacancy? @relation(fields: [vacancyId], references: [id], onDelete: SetNull)
  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([vacancyId])
}
